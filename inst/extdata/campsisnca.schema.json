{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://calvagone.github.io/campsis.doc/schema/1.0/campsisnca.schema.json",
  "$comment": "Campsisnca JSON Schema v1.0 © 2025 [Nicolas Luyckx / Calvagone]. Licensed under CC BY 4.0 (https://creativecommons.org/licenses/by/4.0/). You are free to share and adapt this schema with attribution.",
  "title": "Campsisnca JSON Schema",
  "$ref": "#/$defs/nca_configuration",
  "$defs": {
    "nca_configuration": {
      "type": "object",
      "properties": {
        "strat_vars": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Stratification variable names present in the simulation output. Strata names are automatically identified from the simulation output."
        },
        "nca_analyses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nca_analysis"
          },
          "description": "List of NCA analyses. For example, one analysis may focus on NCA metrics for day 1, and another on those for day 7."
        }
      },
      "required": [
        "strat_vars",
        "nca_analyses"
      ]
    },
    "nca_analysis": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of this analysis. This name will appear in the table. All names must be unique."
        },
        "time_range": {
          "$ref": "#/$defs/nca_time_range",
          "description": "Default time range for this analysis. If not specified, default time range is from 0 to 'last'."
        },
        "variable": {
          "type": "string",
          "description": "Default output variable for this analysis. If not specified, the variable name MUST be specified in each metric."
        },
        "metrics": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "$ref": "#/$defs/auc_metric"
              },
              {
                "$ref": "#/$defs/max_metric"
              },
              {
                "$ref": "#/$defs/cmax_metric"
              },
              {
                "$ref": "#/$defs/min_metric"
              },
              {
                "$ref": "#/$defs/cmin_metric"
              },
              {
                "$ref": "#/$defs/avg_metric"
              },
              {
                "$ref": "#/$defs/cavg_metric"
              },
              {
                "$ref": "#/$defs/last_metric"
              },
              {
                "$ref": "#/$defs/ctrough_metric"
              }
            ]
          }
        }
      },
      "required": [
        "name",
        "metrics"
      ],
      "description": "Definition of a analysis."
    },
    "nca_metric": {
      "title": "Base NCA Metric",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "name": {
          "type": "string",
          "description": "Name of the metric. This name can include grouping variables. E.g. '<METRIC> <PERIOD>'"
        },
        "unit": {
          "type": "string",
          "description": "Informative unit string for this metric."
        },
        "variable": {
          "type": "string",
          "description": "Output variable on which the metric must be computed."
        },
        "stat_display": {
          "type": "string",
          "description": "Statistic display. E.g. '{median} ({p5}–{p95})'."
        },
        "time_range": {
          "$ref": "#/$defs/nca_time_range",
          "description": "Specific time range to use for this metric (e.g. if time range from the analysis needs to be overridden)"
        }
      },
      "required": [
        "type"
      ]
    },
    "auc_metric": {
      "title": "AUC Metric",
      "allOf": [
        {
          "$ref": "#/$defs/nca_metric"
        },
        {
          "properties": {
            "type": {
              "const": "auc_metric"
            },
            "method": {
              "$ref": "#/$defs/auc_method",
              "description": "Method used to compute AUC. If undefined, 'linlin' will be used as the default method."
            }
          },
          "required": [
          ]
        }
      ]
    },
    "abstract_max_metric": {
      "title": "Abstract Max Metric",
      "allOf": [
        {
          "$ref": "#/$defs/nca_metric"
        },
        {
          "properties": {
          },
          "required": [
          ]
        }
      ]
    },
    "max_metric": {
      "title": "Max Metric",
      "allOf": [
        {
          "$ref": "#/$defs/abstract_max_metric"
        },
        {
          "properties": {
            "type": {
              "const": "max_metric"
            }
          },
          "required": [
          ]
        }
      ]
    },
    "cmax_metric": {
      "title": "Cmax Metric",
      "allOf": [
        {
          "$ref": "#/$defs/abstract_max_metric"
        },
        {
          "properties": {
            "type": {
              "const": "cmax_metric"
            }
          },
          "required": [
          ]
        }
      ]
    },
    "abstract_min_metric": {
      "title": "Abstract Min Metric",
      "allOf": [
        {
          "$ref": "#/$defs/nca_metric"
        },
        {
          "properties": {
          },
          "required": [
          ]
        }
      ]
    },
    "min_metric": {
      "title": "Min Metric",
      "allOf": [
        {
          "$ref": "#/$defs/abstract_min_metric"
        },
        {
          "properties": {
            "type": {
              "const": "min_metric"
            }
          },
          "required": [
          ]
        }
      ]
    },
    "cmin_metric": {
      "title": "Cmin Metric",
      "allOf": [
        {
          "$ref": "#/$defs/abstract_min_metric"
        },
        {
          "properties": {
            "type": {
              "const": "cmin_metric"
            }
          },
          "required": [
          ]
        }
      ]
    },
    "abstract_avg_metric": {
      "title": "Abstract Avg Metric",
      "allOf": [
        {
          "$ref": "#/$defs/nca_metric"
        },
        {
          "properties": {
          },
          "required": [
          ]
        }
      ]
    },
    "avg_metric": {
      "title": "Avg Metric",
      "allOf": [
        {
          "$ref": "#/$defs/abstract_avg_metric"
        },
        {
          "properties": {
            "type": {
              "const": "avg_metric"
            }
          },
          "required": [
          ]
        }
      ]
    },
    "cavg_metric": {
      "title": "Cavg Metric",
      "allOf": [
        {
          "$ref": "#/$defs/abstract_avg_metric"
        },
        {
          "properties": {
            "type": {
              "const": "cavg_metric"
            }
          },
          "required": [
          ]
        }
      ]
    },
    "abstract_last_metric": {
      "title": "Abstract Last Metric",
      "allOf": [
        {
          "$ref": "#/$defs/nca_metric"
        },
        {
          "properties": {
          },
          "required": [
          ]
        }
      ]
    },
    "ctrough_metric": {
      "title": "Ctrough Metric",
      "allOf": [
        {
          "$ref": "#/$defs/abstract_last_metric"
        },
        {
          "properties": {
            "type": {
              "const": "ctrough_metric"
            }
          },
          "required": [
          ]
        }
      ]
    },
    "last_metric": {
      "title": "Last Metric",
      "allOf": [
        {
          "$ref": "#/$defs/abstract_last_metric"
        },
        {
          "properties": {
            "type": {
              "const": "last_metric"
            }
          },
          "required": [
          ]
        }
      ]
    },
    "auc_method": {
      "type": "string",
      "enum": [
        "linlin",
        "linlog",
        "tmax_linlog"
      ],
      "description": "Method used to compute AUC"
    },
    "nca_time_range": {
      "title": "NCA time range",
      "type": "object",
      "properties": {
        "start": {
          "type": "number",
          "description": "Start time of the range."
        },
        "end": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "string",
              "pattern": "^last$"
            }
          ],
          "description": "End time of the range. Use 'last' to refer to the last value of the simulation output."
        },
        "time_unit": {
          "$ref": "#/$defs/time_unit",
          "description": "Time unit of properties 'start' and 'end'. Default unit is 'hour."
        },
        "exclude_start": {
          "type": "boolean",
          "description": "Exclude start time. Default is false. If true, the next time point shall delimit the start of the range."
        },
        "exclude_end": {
          "type": "boolean",
          "description": "Exclude end time. Default is false. If true, the previous time point shall delimit the end of the range."
        }
      },
      "required": [
        "start",
        "end"
      ]
    },
    "time_unit": {
      "type": "string",
      "enum": [
        "second",
        "minute",
        "hour",
        "day",
        "week",
        "month",
        "year"
      ]
    }
  }
}
